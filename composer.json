{
    "name": "sukoun/albunyan",
    "type": "project",
    "description": "Sukoun Albunyan Central Command & Enterprise Modular Ecosystem",
    "keywords": ["noble", "erp", "saas", "modular", "laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "anhskohbo/no-captcha": "^3.7",
        "bacon/bacon-qr-code": "^2.0",
        "barryvdh/laravel-dompdf": "^3.1",
        "google/apiclient": "^2.18",
        "inertiajs/inertia-laravel": "^2.0",
        "larabug/larabug": "^3.5",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.2",
        "laravel/socialite": "^5.23",
        "laravel/tinker": "^2.9",
        "league/flysystem-aws-s3-v3": "^3.31",
        "league/oauth2-client": "^2.8",
        "mailchimp/marketing": "^3.0",
        "microsoft/microsoft-graph": "^2.49",
        "phpoffice/phpspreadsheet": "^5.1",
        "pragmarx/google2fa-laravel": "^2.3",
        "pusher/pusher-php-server": "^7.2",
        "salla/zatca": "^3.0",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/laravel-google-calendar": "^3.8",
        "spatie/laravel-medialibrary": "^11.14",
        "spatie/laravel-permission": "^6.21",
        "srmklive/paypal": "^3.0",
        "stripe/stripe-php": "^17.6",
        "tightenco/ziggy": "^2.0",
        "twilio/sdk": "^8.8",
        "webklex/laravel-imap": "^6.2"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.9",
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.0",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Noble\\LandingPage\\": "packages/noble/LandingPage/src/",
            "Noble\\Taskly\\": "packages/noble/Taskly/src/",
            "Noble\\Hrm\\": "packages/noble/Hrm/src/",
            "Noble\\Lead\\": "packages/noble/Lead/src/",
            "Noble\\Pos\\": "packages/noble/Pos/src/",
            "Noble\\AIAssistant\\": "packages/noble/AIAssistant/src/",
            "Noble\\Account\\": "packages/noble/Account/src/",
            "Noble\\BudgetPlanner\\": "packages/noble/BudgetPlanner/src/",
            "Noble\\Calendar\\": "packages/noble/Calendar/src/",
            "Noble\\Contract\\": "packages/noble/Contract/src/",
            "Noble\\DoubleEntry\\": "packages/noble/DoubleEntry/src/",
            "Noble\\FormBuilder\\": "packages/noble/FormBuilder/src/",
            "Noble\\Performance\\": "packages/noble/Performance/src/",
            "Noble\\ProductService\\": "packages/noble/ProductService/src/",
            "Noble\\SupportTicket\\": "packages/noble/SupportTicket/src/",
            "Noble\\Training\\": "packages/noble/Training/src/",
            "Noble\\Recruitment\\": "packages/noble/Recruitment/src/",
            "Noble\\Quotation\\": "packages/noble/Quotation/src/",
            "Noble\\Timesheet\\": "packages/noble/Timesheet/src/",
            "Noble\\GoogleCaptcha\\": "packages/noble/GoogleCaptcha/src/",
            "Noble\\Stripe\\": "packages/noble/Stripe/src/",
            "Noble\\Paypal\\": "packages/noble/Paypal/src/",
            "Noble\\Slack\\": "packages/noble/Slack/src/",
            "Noble\\Telegram\\": "packages/noble/Telegram/src/",
            "Noble\\Twilio\\": "packages/noble/Twilio/src/",
            "Noble\\Webhook\\": "packages/noble/Webhook/src/",
            "Noble\\ZoomMeeting\\": "packages/noble/ZoomMeeting/src/",
            "Noble\\Rental\\": "packages/noble/Rental/src/",
            "Noble\\Goal\\": "packages/noble/Goal/src/"
        },
        "files": [
            "app/Helpers/Helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
